{
  "editor.codeLensFontFamily": "FiraCode-Retina",
  "editor.inlayHints.fontFamily": "FiraCode-Retina",
  "editor.fontLigatures": true,
  "editor.fontSize": 14,
  "editor.tabSize": 2,
  "telemetry.editStats.enabled": false,
  "telemetry.feedback.enabled": false,
  "telemetry.editStats.details.enabled": false,
  "editor.fontFamily": "FiraCode-Retina",
  "editor.minimap.enabled": false,
  "tailwindCSS.emmetCompletions": true,
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.formatOnSave": true,
  "editor.formatOnSaveMode": "file",
  "github.copilot.nextEditSuggestions.enabled": true,
  "git.autofetch": true,
  "js/ts.updateImportsOnFileMove.enabled": "always",
  "diffEditor.renderSideBySide": true,
  "js/ts.preferences.preferTypeOnlyAutoImports": true,
  "js/ts.preferences.includePackageJsonAutoImports": "auto",
  "js/ts.suggest.autoImports": true,
  "diffEditor.experimental.showMoves": true,
  "chat.tools.terminal.outputLocation": "chat",
  "claudeCode.preferredLocation": "panel",
  "chat.viewSessions.orientation": "stacked",
  "continue.showInlineTip": false,
  "claudeCode.usePythonEnvironment": false,
  "security.workspace.trust.untrustedFiles": "open",
  "diffEditor.ignoreTrimWhitespace": false,
  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilot:gpt-4.1",
  "js/ts.experimental.useTsgo": false,
  "diffEditor.hideUnchangedRegions.enabled": true,
  "claudeCode.preferredLocation": "panel",
}
